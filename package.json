{
  "name": "causal-graph-visualizer",
  "version": "1.0.5",
  "description": "Interactive graph visualization and editing tool",
  "author": "Erik",
  "type": "module",
  "main": "electron/electron-main.cjs",
  "homepage": "./",
  "scripts": {
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "dev": "vite --mode web",
    "build": "vite build --mode web",
    "preview": "vite preview",
    "electron:serve": "vite --mode electron",
    "electron:dev": "concurrently \"npm run electron:serve\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "vite build --mode electron && electron .",
    "start": "npm run electron:build",
    "dist": "vite build --mode electron && electron-builder",
    "dist:win": "vite build --mode electron && electron-builder --win",
    "dist:mac": "vite build --mode electron && electron-builder --mac",
    "dist:linux": "vite build --mode electron && electron-builder --linux"
  },
  "build": {
    "appId": "com.erik.causal-graph-visualizer",
    "productName": "Causal Graph Visualizer",
    "publish": null,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "afterSign": "electron/afterSignAdhoc.cjs",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "electron": "^38.1.2",
    "electron-builder": "^25.1.8",
    "jest": "^29.7.0",
    "vite": "^6.3.6",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.0.1",
    "@melloware/coloris": "^0.25.0",
    "d3": "^7.9.0",
    "dagre": "^0.8.5",
    "html2canvas": "^1.4.1",
    "jspdf": "^3.0.3"
  }
}
